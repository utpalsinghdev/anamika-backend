// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@localhost:5432/fundwisor?schema=public"
}

model User {
  id   Int    @unique @default(autoincrement())
  name String
}

model Message {
  id      Int    @unique @default(autoincrement())
  name    String
  email   String
  phone   String
  message String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ROLE {
  AGENT
  DEALERSHIP
  FEILDOFFICER
  ADMIN
  CUSTOMER
}

enum Status {
  APPROVED
  REJECTED
  UNDER_REVIEW
  PENDING
}

model CareerApplication {
  id                Int                        @unique @default(autoincrement())
  title             String
  firstName         String
  role              ROLE
  LastName          String
  Email             String                     @unique
  Phone             String                     @unique
  Status            Status                     @default(PENDING)
  location          String?
  address           String?
  guradian_relation GuardianRelation?
  guardian_name     String?
  ApplicationID     String
  city              String
  profilePic        String?
  docId             Int?                       @unique
  resume            CareerApplicationDocument? @relation(fields: [docId], references: [id])
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  approvedAt        DateTime?
}

model CareerApplicationDocument {
  id        Int                @unique @default(autoincrement())
  name      String
  url       String
  careerDoc CareerApplication?
}

model EmployeeDocument {
  id          Int       @unique @default(autoincrement())
  name        String
  size        String
  url         String
  emoloyeeDoc Employee? @relation(fields: [employeeId], references: [id])
  employeeId  Int?
}

model Employee {
  id                Int                @unique @default(autoincrement())
  employeeCode      String             @unique
  password          String
  e_password        String
  title             String?
  profilePic        String?
  displayPic        String?
  firstName         String
  LastName          String
  location          String?
  address           String?
  guardian_name     String?
  guradian_relation GuardianRelation?
  role              ROLE
  city              String?
  phone             String?
  email             String?
  designation       String?
  resume            EmployeeDocument[]
  resumeId          Int?               @unique
  status            Status             @default(PENDING)
  park              Boolean            @default(false)

  managedBy         Employee?           @relation("ManagedBy", fields: [managedById], references: [id])
  managedById       Int?
  managing          Employee[]          @relation("ManagedBy")
  Customer          Customer[]
  WelcomeLetter     WelcomeLetter[]
  Icard             Icard[]
  AppointmentSalary AppointmentSalary[]
  JointPercent      JointPercent[]

  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Lane {
  FIRST
  SECOND
}

model News {
  id   Int    @unique @default(autoincrement())
  text String
  lane Lane

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GuardianRelation {
  SONOF
  DOF
  WOF
}

enum Type {
  CURRENT
  SAVING
}

model CustomerDocument {
  id                 Int        @unique @default(autoincrement())
  name               String?
  url                String
  applicationId      String
  photoCustomers     Customer[] @relation("photo")
  adharCardCustomers Customer[] @relation("AdharCard")
  proofCustomers     Customer[] @relation("bankProof")
  panCard            Customer[] @relation("panCard")
}

enum Proof {
  PASSBOOK
  CHECQUE
  STATEMENT
}

model Customer {
  id                Int               @unique @default(autoincrement())
  loanId            String            @unique
  name              String
  guardian_relation GuardianRelation
  guardian_name     String
  phone             String
  dob               DateTime?
  email             String?
  loanInNumber      Int
  loanInWords       String
  loanYear          Int
  address           String?
  district          String?
  State             String?
  pinCode           Int?
  agent             Employee          @relation(fields: [employeeId], references: [id])
  employeeId        Int
  bank              String?
  AccountNumber     String?
  ifsc              String?
  accountType       Type?
  photo             CustomerDocument? @relation("photo", fields: [photoId], references: [id])
  photoId           Int?
  AdharCard         CustomerDocument? @relation("AdharCard", fields: [addharId], references: [id])
  addharId          Int?
  adharNumber       String?
  panNumber         String?
  panCard           CustomerDocument? @relation("panCard", fields: [panId], references: [id])
  panId             Int?
  bankProof         Proof?
  proofDoc          CustomerDocument? @relation("bankProof", fields: [proofId], references: [id])
  proofId           Int?
  status            Status

  customerId String?
  password   String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  WelcomeLetter  WelcomeLetter[]
  approval       invoice[]
  ApprovalLetter ApprovalLetter[]
}

model WelcomeLetter {
  id         Int      @unique @default(autoincrement())
  for        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId Int
  with       Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  charge     Int      @default(4130)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Icard {
  id         Int      @unique @default(autoincrement())
  location   String
  agent      Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  profilepic String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppointmentSalary {
  id                Int               @unique @default(autoincrement())
  agent             Employee          @relation(fields: [employeeId], references: [id])
  employeeId        Int
  location          String
  photo             String?
  guradian_relation GuardianRelation?
  guardian_name     String?
  incentive         Int?
  salary_after_pf   String?
  address           String
  salary            String
  agentName         String?
  agentNumber       String?
  targetOne         Int
  targetTwo         Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Method {
  ONLINE
  CASH
  CHECQUE
  NETBANKING
  UPI
}

model invoice {
  id            Int      @unique @default(autoincrement())
  invoiceId     String   @unique
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    Int
  desciption    String
  total         Int
  price         Int?
  qty           Int?
  subT          Int?
  paymentMethod Method
  recived       Int?
  refence       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApprovalLetter {
  id               Int      @unique @default(autoincrement())
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId       Int
  url              String?
  pdfPassword      String?
  address          String
  permanentAddress String
  processingCharge String
  photo            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model JointPercent {
  id             Int      @unique @default(autoincrement())
  agent          Employee @relation(fields: [employeeId], references: [id])
  employeeId     Int
  photo          String
  address        String
  location       String
  file_charge    Int
  loan_amount    Int
  processing_fee Int
  add_charge     Int
  service_tax    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paymentqr {
  id         String   @unique @default(uuid())
  url        String   @unique
  bankName   String
  accountNo  String
  holderName String
  ifsc       String
  fileCharge String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
